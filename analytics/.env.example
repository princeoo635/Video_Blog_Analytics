# MongoDB (source) — point this at the seeded test DB, never production
MONGO_URI=mongodb://127.0.0.1:27017/videoblog_analytics_test
MONGO_DB_NAME=videoblog_analytics_test

# MySQL (destination)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password_here
MYSQL_DATABASE=video_blog_analytics

# Paths (relative to project root, usually leave as-is)
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed
